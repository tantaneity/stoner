{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stoner",
  "version": "0.2.1",
  "identifier": "com.stoner.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Stoner",
        "width": 520,
        "height": 720,
        "resizable": false,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYyQTYzRDE2QjhCMUUwMDEKUldRQjRMRzRGajJtWW9ZOVd1YVpSOVlCTENUNmxSNERCbTZrVUdpaU56VDNwL1JQMU54SG1TUDkK",
      "endpoints": [
        "https://raw.githubusercontent.com/tantaneity/stoner/main/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
